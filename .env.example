# Application
NODE_ENV=development
PORT=3000

# Frontend origin allowed by CORS (in addition to the built-in localhost/LAN/vercel patterns)
FRONTEND_URL=http://localhost:5173

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password123
DB_NAME=games_night
# Dev/test only: set to "false" to disable TypeORM schema auto-sync. Never enable in production.
# DB_SYNCHRONIZE=true

# Redis (cache)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT — CHANGE JWT_SECRET before deploying anywhere real
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
